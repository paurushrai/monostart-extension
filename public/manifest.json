{
  "manifest_version": 3,
  "name": "MonoStart",
  "version": "1.0.0",
  "description": "A hyper-customizable, premium browser dashboard and start page. Elevate your productivity with embedded widgets and instant access.",
  "permissions": ["storage", "unlimitedStorage", "activeTab", "tabs", "history", "alarms", "notifications", "offscreen"],
  "host_permissions": ["*://suggestqueries.google.com/*"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
