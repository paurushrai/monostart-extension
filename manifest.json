{
  "manifest_version": 3,
  "name": "Dashboard",
  "version": "1.0.0",
  "description": "A Notion-style personal dashboard for your links and news.",
  "permissions": ["storage", "unlimitedStorage", "activeTab", "tabs"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
