# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Env files (keep .env.example committed)
.env
.env.*
!.env.example

# Build / tool caches
.vite/
coverage/
*.tsbuildinfo

# Packaged extension artifacts — published via GitHub Releases, not git
*.zip

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local agent / CLI scratch
.antigravitycli/
.claude/
.aider*
.cursor/

# Graphify outputs
graphify-out/

# Extension icons — override the global `Icon?` rule so regenerated PNGs
# are tracked and show up in `git status` (no more `git add -f`).
!public/icons/
!public/icons/*
